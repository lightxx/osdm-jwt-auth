      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}",
            "type": "string"
          }
        ]
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "pm.sendRequest({\r",
              "  url: pm.environment.get('jwt_wrapper_url'),\r",
              "  method: 'POST',\r",
              "  header: {\r",
              "    'Content-Type': 'application/json'\r",
              "  },\r",
              "  body: {\r",
              "    mode: 'raw',\r",
              "    raw: JSON.stringify({\r",
              "      iss: pm.environment.get('iss'),\r",
              "      sub: pm.environment.get('sub'),\r",
              "      aud: pm.environment.get('aud'),\r",
              "      scope: pm.environment.get('scope'),\r",
              "      lifetime: Number(pm.environment.get('lifetime')),\r",
              "      alg: pm.environment.get('alg'),\r",
              "      nbf: pm.environment.get('nbf') === 'true',\r",
              "      iat: pm.environment.get('iat') === 'true',\r",
              "      grace: Number(pm.environment.get('grace'))\r",
              "    })\r",
              "  }\r",
              "}, function (err, res) {\r",
              "  if (err) {\r",
              "    throw err;\r",
              "  }\r",
              "\r",
              "  if (res.code !== 200) {\r",
              "    throw new Error('Token request failed: ' + res.text());\r",
              "  }\r",
              "\r",
              "  const payload = res.json();\r",
              "  pm.environment.set('access_token', payload.access_token);\r",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
